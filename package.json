{
  "name": "os-installation-project",
  "version": "1.0.0",
  "description": "OS Installation & Network Setup Emulator",
  "author": "Arnel",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:exe": "npm run build && npx cross-env CSC_SKIP_SIGNING=true electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.it.os.simulator",
    "productName": "OS-Networking-Simulator",
    "win": {
      "target": "portable",
      "artifactName": "OS-Simulator-v1.exe"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ]
  },
  "dependencies": {
    "lucide-react": "^0.487.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.1"
  }
}
